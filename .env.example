# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/noshirvani?sslmode=disable

# Redis Configuration
REDIS_ADDR=redis:6379

# SMS.ir Configuration (Optional - uses mock mode if not set)
# Get your credentials from https://sms.ir
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=

# JWT Configuration
JWT_SECRET=super-secret-key-change-in-production
JWT_REFRESH_SECRET=refresh-secret
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=1296000

# Server Configuration
SERVER_ADDR=:8080
UPLOAD_PATH=/uploads
OTP_PROVIDER=mock

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

# Admin Configuration
ADMIN_PHONES=09123456789

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
